{
  "app_name": "qq-ai-bot",
  "environment": "development",
  "log_level": "INFO",
  "http": {
    "host": "127.0.0.1",
    "port": 8000,
    "health_path": "/healthz",
    "shutdown_timeout": 5.0
  },
  "storage": {
    "backend": "sqlite",
    "db_path": "data/bot.db"
  },
  "providers": {
    "hoyolab": {
      "qr_timeout": 120.0,
      "region": "cn"
    }
  },
  "onebot": {
    "enabled": true,
    "webhook_host": "0.0.0.0",
    "webhook_port": 18080,
    "webhook_path": "/onebot/v11/",
    "api_base": "http://127.0.0.1:3000"
  },
  "llm": {
    "enabled": false,
    "api_key": "",
    "system_prompt": "你是 genshen，一个智能 AI 助手。"
  }
}
