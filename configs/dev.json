{
  "app_name": "qq-ai-bot",
  "environment": "development",
  "log_level": "INFO",
  "http": {
    "host": "127.0.0.1",
    "port": 8000,
    "health_path": "/healthz",
    "shutdown_timeout": 5.0
  },
  "storage": {
    "backend": "sqlite",
    "db_path": "data/bot.db"
  },
  "providers": {
    "hoyolab": {
      "qr_timeout": 120.0,
      "region": "cn"
    }
  }
}
